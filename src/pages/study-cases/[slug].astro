---
import "@app/styles/global.css";
import Layout from "@app/layouts/Layout.astro";
import Button from "@shared/components/ui/button.astro";
import { getEntry, render } from "astro:content";

const slug = Astro.params.slug;

if (!slug) {
    return new Response(null, { status: 404, statusText: "Not found" });
}

const entry = await getEntry("blog", slug);

if (!entry) {
    return new Response(null, { status: 404, statusText: "Not found" });
}

const { Content } = await render(entry);
---

<Layout>
    <article class="min-h-screen px-4 pt-32 pb-16 md:px-6 md:pt-40 md:pb-24">
        <div class="mx-auto w-full max-w-2xl">
            <!-- Navigation -->
            <nav class="mb-12">
                <a 
                    href="/#projects" 
                    class="group flex items-center gap-2 text-sm font-medium font-manrope text-zinc-500 transition-colors hover:text-emerald-700"
                >
                    <svg 
                        xmlns="http://www.w3.org/2000/svg" 
                        width="16" 
                        height="16" 
                        viewBox="0 0 24 24" 
                        fill="none" 
                        stroke="currentColor" 
                        stroke-width="2" 
                        stroke-linecap="round" 
                        stroke-linejoin="round" 
                        class="transition-transform group-hover:-translate-x-1"
                    >
                        <path d="m15 18-6-6 6-6"/>
                    </svg>
                    Volver a proyectos
                </a>
            </nav>

            <header class="mb-12 border-b border-emerald-900/10 pb-12">
                <div class="flex items-center gap-3 mb-6">
                    <span class="text-xs font-bold tracking-widest uppercase text-emerald-700/80">
                        Caso de estudio
                    </span>
                    <span class="text-zinc-300">•</span>
                    <time datetime={entry.data.pubDate.toISOString()} class="text-sm text-zinc-500">
                        {
                            entry.data.pubDate.toLocaleDateString("es-ES", {
                                year: "numeric",
                                month: "long",
                                day: "numeric",
                            })
                        }
                    </time>
                </div>
                
                <h1
                    class="text-balance text-4xl font-bold font-ibm-plex-serif leading-[1.15] text-emerald-950 md:text-6xl"
                >
                    {entry.data.title}
                </h1>
                
                {entry.data.description && (
                    <p class="mt-8 text-xl leading-relaxed text-zinc-600 font-medium">
                        {entry.data.description}
                    </p>
                )}
            </header>

            <section class="prose prose-zinc study-case-prose max-w-none">
                <Content />
            </section>

            <footer class="mt-24 border-t border-emerald-900/10 pt-16 flex justify-center">
                <Button 
                    variant="default" 
                    link="/#contact"
                >
                    ¿Tienes un proyecto similar? Hablemos
                </Button>
            </footer>
        </div>
    </article>
</Layout>
