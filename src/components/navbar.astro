---
const linkWrapper =
    "before:min-w-full before:left-0 before:top-1/2 before:-translate-y-1/2 before:py-2 before:px-2 before:absolute before:block before:opacity-0 hover:before:opacity-40 relative after:absolute after:bottom-0 after:left-0 after:h-0.5 after:bg-black after:transition-all after:duration-300 after:ease-in-out after:w-0 hover:after:w-full";

const logoWrapper =
    "before:min-w-full before:left-0 before:top-1/2 before:-translate-y-1/2 before:py-2 before:px-2 before:absolute before:block before:opacity-0 hover:before:opacity-40 relative";
---

<nav
    data-site-nav
    class="w-full px-4 md:px-8 lg:px-0 py-4 md:py-8 fixed justify-between bg-white/10 backdrop-blur-sm border-b border-white/20 z-50 overflow-x-hidden overflow-y-hidden"
>
    <div class="container mx-auto flex justify-between items-center">
        <div class="relative w-12 h-12">
            <a class={logoWrapper} href="/#hero" aria-label="Inicio">
                <img src="/sync_logo.webp" alt="SYNC Estudio" class="h-full w-full object-contain" />
            </a>
        </div>

        <ul class="flex gap-3 md:gap-6 lg:gap-12 text-sm md:text-base" role="menubar" aria-label="Navegación principal">
            <li class="relative">
                <a class={linkWrapper} href="/#hero" role="menuitem">Inicio</a>
            </li>
            <li class="relative">
                <a class={linkWrapper} href="/#about" role="menuitem">Nosotros</a>
            </li>
            <li class="relative">
                <a class={linkWrapper} href="/#projects" role="menuitem">Proyectos</a>
            </li>
            <li class="relative">
                <a class={linkWrapper} href="/#contact" role="menuitem">Contacto</a>
            </li>
        </ul>
    </div>
</nav>
