---
import ProjectCard from "../project-card.astro";
import ProjectCardReact from "../react/project-card";
---

<section id="projects" class="h-fit container mx-auto text-center px-4 md:px-0">
    <div class="font-normal mt-20 md:mt-30 mb-12 md:mb-16">
        <h3
            class="font-[ibm-plex-serif] text-lg md:text-xl font-bold italic text-emerald-900"
        >
            Proyectos
        </h3>
        <p class="text-2xl md:text-3xl">Nuestro trabajo</p>
    </div>

    <div
        class="flex flex-wrap justify-center gap-4 md:gap-6 lg:gap-8 overflow-y-hidden"
    >
        <ProjectCardReact
            client:load
            data={{ name: "Hauzzo", year: "2024" }}
            image="/hauzzo_project.webp"
        />
        <ProjectCardReact
            client:load
            data={{ name: "The Royal Barber", year: "2024" }}
            style="sm:w-60 md:translate-y-20"
            image="/the_royal_project.webp"
        />
        <ProjectCardReact
            client:load
            data={{ name: "Sky HR", year: "2025", development: true }}
            style="md:w-full md:translate-y-2"
            image="/sky_hr_project.webp"
        />
        <ProjectCardReact
            client:load
            data={{ name: "GZG Seguros", year: "2025" }}
            image="/gzg_project.webp"
        />
    </div>
</section>
