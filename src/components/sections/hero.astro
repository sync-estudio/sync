---
import "../../styles/global.css";
import Button from "../../components/button.astro";
---

<div
    id="hero"
    class="min-h-[90vh] py-20 md:py-24 container mx-auto flex justify-center items-center"
>
    <div
        class="flex flex-col gap-8 sm:gap-7 md:gap-8 lg:gap-10 w-full max-w-8xl lg:my-auto pt-0 lg:pt-20"
    >
        <div class="text-zinc-800 text-start">
            <h1
                class="text-4xl sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-semibold mb-4 sm:mb-4 md:mb-5 leading-tight px-2 sm:px-4"
            >
                Software a medida para empresas en operación, enfocado en <br
                    class="hidden sm:block"
                />
                <span
                    class="font-[ibm-plex-serif] font-bold italic text-emerald-900 relative inline-block px-2.5 py-1.5 sm:px-3 sm:py-1.5 md:px-4 md:py-2"
                    ><span
                        class="absolute inset-0 bg-emerald-200/60 -rotate-1 transform origin-center rounded-sm -mx-1"
                    ></span><span class="relative z-10">resultados reales.</span
                    ></span
                >
            </h1>
        </div>

        <div
            class="flex flex-wrap justify-start gap-4 sm:gap-5 md:gap-6 w-full px-4 sm:px-0"
        >
            <Button
                link="/#contact"
                >Solicitar consultoría inicial</Button
            >
            <Button
                link="/#contact"
                variant="ghost"
                >Explorar soluciones</Button
            >
        </div>
    </div>
</div>

<style>
    @media (min-width: 640px) {
        #hero img {
            max-height: 600px;
            min-height: 400px;
        }
    }

    @media (min-width: 768px) {
        #hero img {
            max-height: 700px;
            min-height: 500px;
        }
    }

    @media (min-width: 1024px) {
        #hero img {
            max-height: 800px;
            min-height: 600px;
        }
    }

    @media (min-width: 1280px) {
        #hero img {
            max-height: 900px;
            min-height: 700px;
        }
    }
</style>
