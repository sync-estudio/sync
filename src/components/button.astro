---
interface Props {
    variant?: "default" | "outline" | "ghost"
    style?: string,
    link?: string
}

const { variant = "default", style = "", link } = Astro.props

const variants = {
    default: "cursor-pointer px-6 py-3 bg-zinc-800 text-white rounded-full transition-all duration-200 ease-in-out hover:bg-zinc-700 hover:scale-[1.02] hover:shadow-md active:scale-[0.98] active:bg-zinc-900 focus:outline-none focus:ring-2 focus:ring-zinc-600 focus:ring-offset-2",
    outline: "cursor-pointer px-6 py-3 bg-transparent text-zinc-800 border border-zinc-800 rounded-full transition-all duration-200 ease-in-out hover:bg-zinc-800 hover:text-white hover:scale-[1.02] hover:shadow-md active:scale-[0.98] active:bg-zinc-900 active:text-white focus:outline-none focus:ring-2 focus:ring-zinc-600 focus:ring-offset-2",
    ghost: "cursor-pointer px-4 py-2 text-gray-700 rounded-lg transition-all duration-200 ease-in-out hover:bg-gray-100 hover:text-gray-900 hover:scale-[1.02] active:scale-[0.98] active:bg-gray-200 focus:outline-none focus:ring-2 focus:ring-gray-400 focus:ring-offset-2"
}
---

{link ? (
    <a href={link} class={`${style} ${variants[variant]}`}>
        <slot />
    </a>
) : (
    <button class={`${style} ${variants[variant]}`}>
        <slot />
    </button>
)}