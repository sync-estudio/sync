---
// Footer component
---

<footer class="bg-white/10 backdrop-blur-md border-t border-white/10 mt-auto w-full">
	<div class="container mx-auto px-4 md:px-8 py-8 md:py-12">
		<div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
			<!-- Logo y descripción -->
			<div class="space-y-3 md:space-y-4 text-center md:text-left">
				<div class="flex items-center justify-center md:justify-start space-x-2">
					<span class="text-xl md:text-2xl font-bold text-emerald-900">SYNC</span>
				</div>
				<p class="text-zinc-600 max-w-xs mx-auto md:mx-0 text-sm md:text-base">
					Estudio creativo especializado en diseño digital y desarrollo web. Creamos experiencias únicas que conectan marcas con su audiencia.
				</p>
			</div>

			<!-- Enlaces rápidos -->
			<div class="space-y-3 md:space-y-4 text-center md:text-left">
				<h3 class="font-semibold text-zinc-800">Enlaces</h3>
				<ul class="space-y-2">
					<li><a href="#inicio" class="text-zinc-600 hover:text-emerald-600 transition-colors">Inicio</a></li>
					<li><a href="#proyectos" class="text-zinc-600 hover:text-emerald-600 transition-colors">Proyectos</a></li>
					<li><a href="#sobre-nosotros" class="text-zinc-600 hover:text-emerald-600 transition-colors">Sobre Nosotros</a></li>
					<li><a href="#contacto" class="text-zinc-600 hover:text-emerald-600 transition-colors">Contacto</a></li>
				</ul>
			</div>

			<!-- Contacto -->
			<div class="space-y-3 md:space-y-4 text-center md:text-left">
				<h3 class="font-semibold text-zinc-800">Contacto</h3>
				<div class="space-y-2 text-zinc-600 text-sm md:text-base">
					<p>hola@syncestudio.com</p>
					<p>+52 55 1234 5678</p>
					<p>Ciudad de México, México</p>
				</div>
