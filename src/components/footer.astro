---
const linkWrapper =
    "before:min-w-full before:left-6/12 before:top-6/12 before:translate-y-[-50%] before:translate-x-[-50%] before:box-content before:py-4 before:px-2 before:absolute before:block before:opacity-40";
---

<footer class="bg-white/10 backdrop-blur-md border-t border-white/10 mt-auto w-full">
	<div class="container mx-auto px-4 md:px-8 py-8 md:py-12">
		<div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
			<!-- Logo y descripción -->
			<div class="space-y-3 md:space-y-4 text-center md:text-left">
				<div class="flex items-center justify-center md:justify-start space-x-2">
					<div class="relative w-fit">
						<a class={linkWrapper} href="/#hero">
							<img src="/sync_logo.svg" alt="SYNC Estudio" />
						</a>
					</div>
				</div>
				<p class="text-zinc-600 max-w-xs mx-auto md:mx-0 text-sm md:text-base">
					Estudio creativo especializado en diseño digital y desarrollo web. Creamos experiencias únicas que conectan marcas con su audiencia.
				</p>
			</div>

			<!-- Enlaces rápidos -->
			<div class="space-y-3 md:space-y-4 text-center md:text-left">
				<h3 class="font-semibold text-zinc-800">Enlaces</h3>
				<ul class="space-y-2">
					<li class="relative"><a href="/#hero" class={`text-zinc-600 hover:text-emerald-600 transition-colors ${linkWrapper}`}>Inicio</a></li>
					<li class="relative"><a href="/#projects" class={`text-zinc-600 hover:text-emerald-600 transition-colors ${linkWrapper}`}>Proyectos</a></li>
					<li class="relative"><a href="/#about" class={`text-zinc-600 hover:text-emerald-600 transition-colors ${linkWrapper}`}>Sobre Nosotros</a></li>
					<li class="relative"><a href="/#contact" class={`text-zinc-600 hover:text-emerald-600 transition-colors ${linkWrapper}`}>Contacto</a></li>
				</ul>
			</div>

			<!-- Contacto -->
			<div class="space-y-3 md:space-y-4 text-center md:text-left">
				<h3 class="font-semibold text-zinc-800">Contacto</h3>
				<div class="space-y-2 text-zinc-600 text-sm md:text-base">
					<p>hola@syncestudio.com</p>
					<p>+52 222 2823 0805</p>
					<p>Puebla, México</p>
				</div>
				<div class="flex justify-center md:justify-start pt-2">
					<a href="https://www.instagram.com/sync.estudio/" target="_blank" rel="noopener noreferrer" class={`text-zinc-600 hover:text-emerald-600 transition-colors relative ${linkWrapper}`}>
						<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
							<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
						</svg>
					</a>
				</div>
			</div>
		</div>

		<div class="border-t border-white/20 mt-6 md:mt-8 pt-6 md:pt-8 text-center">
			<p class="text-zinc-500 text-xs md:text-sm">
				© 2025 SYNC Estudio. Todos los derechos reservados.
			</p>
		</div>
	</div>
</footer>
