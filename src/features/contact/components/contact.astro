---
import "@app/styles/global.css";
import Button from "@shared/components/ui/button.astro";
---

<section id="contact" class="container mx-auto text-center mt-20 md:mt-32">
    <div class="bg-gray-50 rounded-2xl p-6 md:p-8 lg:py-12">
        <div class="font-normal">
            <h3
                class="font-[ibm-plex-serif] text-lg md:text-xl font-bold italic text-emerald-900"
            >
                Contacto:
            </h3>
            <p class="text-2xl md:text-3xl leading-tight px-2 md:px-0">
                ¿Listo para empezar tu
                <span
                    class="font-[ibm-plex-serif] italic font-semibold text-zinc-700"
                    >transformación digital?</span
                >
            </p>
        </div>

        <div class="mt-6 md:mt-8">
            <p class="mb-4 md:mb-6 text-sm md:text-base px-2 md:px-0">
                Cuéntanos sobre tu proyecto y te ayudaremos a llevarlo al siguiente nivel.
            </p>
            
            <form id="contactForm" class="max-w-md mx-auto space-y-3 md:space-y-4 mb-4 md:mb-6" novalidate>
                <div>
                    <input 
                        type="text" 
                        id="name" 
                        name="name" 
                        placeholder="Tu nombre" 
                        aria-label="Nombre"
                        autocomplete="name"
                        required
                        minlength="2"
                        maxlength="50"
                        pattern="^[a-zA-ZáéíóúÁÉÍÓÚñÑ\s]+$"
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-colors duration-200"
                        data-valid="false"
                    >
                    <div id="nameError" class="hidden text-left mt-1 text-sm text-red-600"></div>
                </div>
                <div>
                    <input 
                        type="email" 
                        id="email" 
                        name="email" 
                        placeholder="Tu email" 
                        aria-label="Correo electrónico"
                        autocomplete="email"
                        required
                        pattern="[a-z0-9._%+-]+@[a-z0-9.-]+\.[a-z]{2,}$"
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-colors duration-200"
                        data-valid="false"
                    >
                    <div id="emailError" class="hidden text-left mt-1 text-sm text-red-600"></div>
                </div>
                <div>
                    <textarea 
                        id="message" 
                        name="message" 
                        placeholder="Cuéntanos sobre tu proyecto" 
                        aria-label="Mensaje"
                        autocomplete="off"
                        rows="4" 
                        required
                        minlength="10"
                        maxlength="500"
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 resize-none transition-colors duration-200"
                        data-valid="false"
                    ></textarea>
                    <div id="messageError" class="hidden text-left mt-1 text-sm text-red-600"></div>
                    <div class="text-right mt-1 text-xs text-gray-500">
                        <span id="messageCount">0</span>/500 caracteres
                    </div>
                </div>
                <div class="flex flex-col items-center gap-4">
                    <Button style="w-full transition-all duration-200 ease-in-out hover:bg-emerald-700 hover:scale-[1.02] hover:shadow-md active:scale-[0.98] active:bg-emerald-800 focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 focus:outline-none">
                        Enviar Mensaje
                    </Button>
                    <span class="text-gray-500">o</span>
                    <Button variant="outline" blank link="https://wa.me/522228230805?text=Hola%2C%20me%20gustar%C3%ADa%20saber%20m%C3%A1s%20sobre%20sus%20servicios.">Envíanos un WhatsApp</Button>
                </div>
            </form>
        </div>
    </div>
</section>

<script>
// Validaciones
const validations: Record<string, Record<string, string>> = {
    name: {
        required: 'El nombre es requerido',
        minlength: 'El nombre debe tener al menos 2 caracteres',
        maxlength: 'El nombre no puede exceder 50 caracteres',
        pattern: 'El nombre solo puede contener letras y espacios'
    },
    email: {
        required: 'El email es requerido',
        pattern: 'Por favor ingresa un email válido'
    },
    message: {
        required: 'El mensaje es requerido',
        minlength: 'El mensaje debe tener al menos 10 caracteres',
        maxlength: 'El mensaje no puede exceder 500 caracteres'
    }
};

// Función para mostrar errores
function showError(fieldId: string, message: string): void {
    const field = document.getElementById(fieldId) as HTMLInputElement | HTMLTextAreaElement;
    const errorDiv = document.getElementById(fieldId + 'Error');
    
    if (errorDiv) {
        errorDiv.textContent = message;
        errorDiv.classList.remove('hidden');
    }
    
    if (field) {
        field.classList.remove('border-gray-300', 'focus:ring-emerald-500', 'focus:border-emerald-500');
        field.classList.add('border-red-500', 'focus:ring-red-500', 'focus:border-red-500');
        field.setAttribute('data-valid', 'false');
    }
}

// Función para ocultar errores
function hideError(fieldId: string): void {
    const field = document.getElementById(fieldId) as HTMLInputElement | HTMLTextAreaElement;
    const errorDiv = document.getElementById(fieldId + 'Error');
    
    if (errorDiv) {
        errorDiv.classList.add('hidden');
    }
    
    if (field) {
        field.classList.remove('border-red-500', 'focus:ring-red-500', 'focus:border-red-500');
        field.classList.add('border-gray-300', 'focus:ring-emerald-500', 'focus:border-emerald-500');
        field.setAttribute('data-valid', 'true');
    }
}

// Función para validar un campo
function validateField(fieldId: string): boolean {
    const field = document.getElementById(fieldId) as HTMLInputElement | HTMLTextAreaElement;
    if (!field) return false;
    
    const value = field.value.trim();
    const rules = validations[fieldId];
    
    // Validación required
    if (rules.required && !value) {
        showError(fieldId, rules.required);
        return false;
    }
    
    // Validación minlength
    if (rules.minlength && value.length < parseInt(field.getAttribute('minlength') || '0')) {
        showError(fieldId, rules.minlength);
        return false;
    }
    
    // Validación maxlength
    if (rules.maxlength && value.length > parseInt(field.getAttribute('maxlength') || '0')) {
        showError(fieldId, rules.maxlength);
        return false;
    }
    
    // Validación pattern
    if (rules.pattern && field.getAttribute('pattern')) {
        const pattern = field.getAttribute('pattern');
        if (pattern) {
            const regex = new RegExp(pattern);
            if (!regex.test(value)) {
                showError(fieldId, rules.pattern);
                return false;
            }
        }
    }
    
    hideError(fieldId);
    return true;
}

// Función para validar todo el formulario
function validateForm(): boolean {
    const fields = ['name', 'email', 'message'];
    let isValid = true;
    
    fields.forEach(fieldId => {
        if (!validateField(fieldId)) {
            isValid = false;
        }
    });
    
    return isValid;
}

// Función para actualizar contador de caracteres
function updateMessageCount(): void {
    const messageField = document.getElementById('message') as HTMLTextAreaElement;
    const countElement = document.getElementById('messageCount');
    
    if (messageField && countElement) {
        const count = messageField.value.length;
        countElement.textContent = count.toString();
        
        // Cambiar color según la longitud
        if (count > 450) {
            countElement.classList.add('text-red-500');
            countElement.classList.remove('text-gray-500');
        } else if (count > 400) {
            countElement.classList.add('text-yellow-500');
            countElement.classList.remove('text-gray-500', 'text-red-500');
        } else {
            countElement.classList.remove('text-red-500', 'text-yellow-500');
            countElement.classList.add('text-gray-500');
        }
    }
}

// Event listeners para validación en tiempo real
document.addEventListener('DOMContentLoaded', () => {
    const nameField = document.getElementById('name') as HTMLInputElement;
    const emailField = document.getElementById('email') as HTMLInputElement;
    const messageField = document.getElementById('message') as HTMLTextAreaElement;
    const submitBtn = document.querySelector('#contactForm button');
    
    // Validación en tiempo real para nombre
    nameField?.addEventListener('input', () => {
        validateField('name');
    });
    
    nameField?.addEventListener('blur', () => {
        validateField('name');
    });
    
    // Validación en tiempo real para email
    emailField?.addEventListener('input', () => {
        validateField('email');
    });
    
    emailField?.addEventListener('blur', () => {
        validateField('email');
    });
    
    // Validación en tiempo real para mensaje
    messageField?.addEventListener('input', () => {
        validateField('message');
        updateMessageCount();
    });
    
    messageField?.addEventListener('blur', () => {
        validateField('message');
    });
    
    // Agregar el atributo type="submit" al botón
    if (submitBtn) {
        submitBtn.setAttribute('type', 'submit');
    }
});

// Manejo del envío del formulario
document.getElementById('contactForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // Validar antes de enviar
    if (!validateForm()) {
        // Encontrar el primer campo con error y hacer focus
        const fields = ['name', 'email', 'message'];
        for (const fieldId of fields) {
            const field = document.getElementById(fieldId) as HTMLInputElement | HTMLTextAreaElement;
            if (field && field.getAttribute('data-valid') === 'false') {
                field.focus();
                break;
            }
        }
        return;
    }
    
    const target = e.target as HTMLFormElement;
    const formData = new FormData(target);
    const data = {
        name: formData.get('name'),
        email: formData.get('email'),
        message: formData.get('message')
    };
    
    const submitButton = target.querySelector('button') as HTMLButtonElement;
    const originalText = submitButton.textContent;
    submitButton.textContent = 'Enviando...';
    submitButton.disabled = true;
    
    try {
        const response = await fetch('https://mail.syncestudio.com/send', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify(data)
        });
        
        const result = await response.json();
        
        if (result.success) {
            alert('¡Mensaje enviado con éxito! Te contactaremos pronto.');
            target.reset();
            // Resetear contador y estados de validación
            updateMessageCount();
            ['name', 'email', 'message'].forEach(fieldId => {
                hideError(fieldId);
                const field = document.getElementById(fieldId) as HTMLInputElement | HTMLTextAreaElement;
                if (field) {
                    field.setAttribute('data-valid', 'false');
                }
            });
        } else {
            alert('Error al enviar el mensaje. Por favor, intenta de nuevo.');
        }
    } catch (error) {
        alert('Error de conexión. Por favor, intenta de nuevo.');
        console.error('Error:', error);
    } finally {
        submitButton.textContent = originalText;
        submitButton.disabled = false;
    }
});
</script>
