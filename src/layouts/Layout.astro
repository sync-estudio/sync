---
import "../styles/global.css";
import Navbar from "../components/navbar.astro";
import Footer from "../components/footer.astro";
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>SYNC Estudio — Diseño digital y desarrollo web</title>

		<meta name="description" content="Estudio creativo especializado en diseño digital y desarrollo web. Creamos experiencias únicas que conectan marcas con su audiencia." />
		<meta name="theme-color" content="#10b981" />
		<meta name="robots" content="index,follow" />

		<!-- Preconnect for Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="SYNC Estudio" />
		<meta property="og:title" content="SYNC Estudio — Diseño digital y desarrollo web" />
		<meta property="og:description" content="Estudio creativo especializado en diseño digital y desarrollo web. Creamos experiencias únicas que conectan marcas con su audiencia." />
		<meta property="og:locale" content="es_ES" />
		<meta property="og:image" content="/share_image.png" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content="SYNC Estudio - Tu empresa, funcionando en internet" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="SYNC Estudio — Diseño digital y desarrollo web" />
		<meta name="twitter:description" content="Estudio creativo especializado en diseño digital y desarrollo web. Creamos experiencias únicas que conectan marcas con su audiencia." />
		<meta name="twitter:image" content="/share_image.png" />
		<meta name="twitter:image:alt" content="SYNC Estudio - Tu empresa, funcionando en internet" />

		<!-- Structured Data: Organization -->
		<script type="application/ld+json">
			{ 
				"@context": "https://schema.org", 
				"@type": "Organization",
				"name": "SYNC Estudio",
				"logo": "/sync_logo.svg",
				"sameAs": ["https://www.instagram.com/sync.estudio/"]
			}
		</script>
	</head>

	<body
		class="min-h-screen font-[Manrope] text-zinc-800 relative overflow-x-hidden" style="background-image: url('/bg_texture.png'); background-size: 150px; background-repeat: repeat;"
	>
		<Navbar />
		
		<div class="pb-32">
			<slot />
		</div>
		
		<Footer />
		<script>
			// Scroll suave para enlaces de anclas con offset para navbar fijo
			document.addEventListener('DOMContentLoaded', () => {
				const anchorLinks = document.querySelectorAll('a[href^="/#"]');
				
				// Función para obtener la altura del navbar según el dispositivo
				const getNavbarHeight = () => {
					return window.innerWidth <= 768 ? 20 : 80; // 20px en móvil, 80px en desktop
				};
				
				anchorLinks.forEach(link => {
					link.addEventListener('click', (e) => {
						e.preventDefault();
						
						const href = link.getAttribute('href');
						if (href && href.startsWith('/#')) {
							const targetId = href.substring(2); // Remover "/#"
							const targetElement = document.getElementById(targetId);
							
							if (targetElement) {
								const navbarHeight = getNavbarHeight();
								const targetPosition = targetElement.offsetTop - navbarHeight;
								
								window.scrollTo({
									top: targetPosition,
									behavior: 'smooth'
								});
							}
						}
					});
				});
			});
		</script>
	</body>
</html>
