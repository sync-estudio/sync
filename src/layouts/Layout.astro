---
import "../styles/global.css";
import Navbar from "../components/navbar.astro";
import Footer from "../components/footer.astro";
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>SYNC Estudio — Diseño digital y desarrollo web</title>

		<meta name="description" content="Estudio creativo especializado en diseño digital y desarrollo web. Creamos experiencias únicas que conectan marcas con su audiencia." />
		<meta name="theme-color" content="#10b981" />
		<meta name="robots" content="index,follow" />

		<!-- Preconnect for Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="SYNC Estudio" />
		<meta property="og:title" content="SYNC Estudio — Diseño digital y desarrollo web" />
		<meta property="og:description" content="Estudio creativo especializado en diseño digital y desarrollo web. Creamos experiencias únicas que conectan marcas con su audiencia." />
		<meta property="og:locale" content="es_ES" />
		<meta property="og:image" content="/share_image.png" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content="SYNC Estudio - Tu empresa, funcionando en internet" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="SYNC Estudio — Diseño digital y desarrollo web" />
		<meta name="twitter:description" content="Estudio creativo especializado en diseño digital y desarrollo web. Creamos experiencias únicas que conectan marcas con su audiencia." />
		<meta name="twitter:image" content="/share_image.png" />
		<meta name="twitter:image:alt" content="SYNC Estudio - Tu empresa, funcionando en internet" />

		<!-- Structured Data: Organization -->
		<script type="application/ld+json">
			{ 
				"@context": "https://schema.org", 
				"@type": "Organization",
				"name": "SYNC Estudio",
				"logo": "/sync_logo.svg",
				"sameAs": ["https://www.instagram.com/sync.estudio/"]
			}
		</script>
		<style is:global>
			:root {
				--anchor-scroll-offset: 0px;
				--anchor-scroll-gap: 16px;
			}

			:where(#hero, #about, #projects, #contact) {
				scroll-margin-top: calc(var(--anchor-scroll-offset) + var(--anchor-scroll-gap));
			}
		</style>
	</head>

	<body
		class="min-h-screen font-[Manrope] text-zinc-800 relative overflow-x-hidden" style="background-image: url('/bg_texture.png'); background-size: 150px; background-repeat: repeat;"
	>
		<Navbar />
		
		<div class="pb-32">
			<slot />
		</div>
		
		<Footer />
		<script>
			document.addEventListener("DOMContentLoaded", () => {
				const anchorGap = 16;
				const sectionPath = "/";
				let resizeFrame = 0;

				const getNavbarOffset = () => {
					const navbar = document.querySelector("[data-site-nav]");
					const navbarHeight = navbar instanceof HTMLElement ? navbar.getBoundingClientRect().height : 0;

					return Math.max(0, Math.ceil(navbarHeight));
				};

				const syncAnchorOffset = () => {
					document.documentElement.style.setProperty("--anchor-scroll-offset", `${getNavbarOffset()}px`);
				};

				const getSectionElement = (hash: string) => {
					const sectionId = decodeURIComponent(hash.replace(/^#/, ""));

					if (!sectionId) {
						return null;
					}

					return document.getElementById(sectionId);
				};

				const scrollToHash = (hash: string, behavior: ScrollBehavior) => {
					const targetElement = getSectionElement(hash);

					if (!targetElement) {
						return;
					}

					const targetPosition = window.scrollY + targetElement.getBoundingClientRect().top - getNavbarOffset() - anchorGap;

					window.scrollTo({
						top: Math.max(0, targetPosition),
						behavior
					});
				};

				syncAnchorOffset();

				document.addEventListener("click", (event) => {
					const target = event.target;
					const link = target instanceof Element ? target.closest('a[href^="/#"]') : null;

					if (!(link instanceof HTMLAnchorElement)) {
						return;
					}

					const url = new URL(link.href, window.location.origin);

					if (url.pathname !== sectionPath || window.location.pathname !== sectionPath) {
						return;
					}

					const targetElement = getSectionElement(url.hash);

					if (!targetElement) {
						return;
					}

					event.preventDefault();
					syncAnchorOffset();
					scrollToHash(url.hash, "smooth");

					if (window.location.hash !== url.hash) {
						history.pushState(null, "", `${sectionPath}${url.hash}`);
					}
				});

				window.addEventListener("load", () => {
					syncAnchorOffset();

					if (window.location.pathname === sectionPath && window.location.hash) {
						scrollToHash(window.location.hash, "auto");
					}
				});

				window.addEventListener("hashchange", () => {
					if (window.location.pathname !== sectionPath || !window.location.hash) {
						return;
					}

					syncAnchorOffset();
					scrollToHash(window.location.hash, "auto");
				});

				window.addEventListener("resize", () => {
					cancelAnimationFrame(resizeFrame);
					resizeFrame = window.requestAnimationFrame(() => {
						syncAnchorOffset();

						if (window.location.pathname === sectionPath && window.location.hash) {
							scrollToHash(window.location.hash, "auto");
						}
					});
				});
			});
		</script>
	</body>
</html>
